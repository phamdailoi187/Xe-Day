#include <HX711_ADC.h> 
#include <EEPROM.h> 
#include <WiFi.h>
#include <WiFiManager.h> 
#include <HTTPClient.h>
#include <WiFiClientSecure.h>

// --- 1. KHAI BÁO CẢM BIẾN LOADCELL (Đúng chuẩn bo mạch Lợi vừa hàn) ---
const int HX711_dout_L = 19;
const int HX711_sck_L = 18;
const int HX711_dout_R = 33;
const int HX711_sck_R = 32; 

HX711_ADC LoadCell_L(HX711_dout_L, HX711_sck_L);
HX711_ADC LoadCell_R(HX711_dout_R, HX711_sck_R);

float calibrationValue_L = 102430.0; // Đã xóa dòng trùng lặp
float calibrationValue_R = 99806.0;

// --- 2. KHAI BÁO CẢM BIẾN TỐC ĐỘ (NAM CHÂM) ---
const int hallPin = 25; // Chân hoa hậu D25 cho bo mạch mới
const float PI_VAL = 3.14159; 
const float diameter = 0.125; // d = 12.5cm
const int numMagnets = 5;     // Số nam châm

const float distancePerTick = (diameter * PI_VAL) / numMagnets; 
volatile unsigned long magnetHits = 0; 
volatile unsigned long lastDebounceTime = 0; 
unsigned long previousHits = 0;

// --- 3. KHAI BÁO SERVER & TIMER ---
// Khai báo "Địa chỉ nhà" gốc
const String baseUrl = "https://breeze-fencing-elaborate.ngrok-free.dev";
String device_id;
unsigned long t = 0;

// Thêm biến đếm thời gian cho tính năng Ping (3 phút)
unsigned long lastPingTime = 0; 
const unsigned long pingInterval = 180000; // 3 phút = 180.000 ms

WiFiManager wm;

// --- HÀM NGẮT (Đếm nam châm) - Phải có IRAM_ATTR cho ESP32 ---
void IRAM_ATTR countMagnet() {
  unsigned long currentMillis = millis();
  // Chặn 400ms để test thủ công bằng tay (Lúc gắn lên xe chạy thật nhớ hạ xuống 50)
  if (currentMillis - lastDebounceTime > 400) { 
    magnetHits++;
    lastDebounceTime = currentMillis;
  }
}

TaskHandle_t TaskCore0; // Biến quản lý Lõi 0

// Hàm này sẽ chạy độc lập trên Lõi 0
void docLoadCell(void * parameter) {
  for(;;) {
    LoadCell_L.update(); // Đọc cân trái
    LoadCell_R.update(); // Đọc cân phải
    delay(10); // Nghỉ 10ms để nhường tài nguyên, không làm cháy chip
  }
}

void setup() {
  Serial.begin(115200); 
  delay(10);
  Serial.println("Dang khoi dong...");
  pinMode(2, OUTPUT); // LED báo WiFi

  // --- Cài đặt Ngắt cho cảm biến từ ---
  pinMode(hallPin, INPUT_PULLUP);
  attachInterrupt(digitalPinToInterrupt(hallPin), countMagnet, FALLING);

  // --- Cài đặt WiFi Manager ---
  std::vector<const char *> menu = {"wifi", "exit"};
  wm.setMenu(menu);
  wm.setTitle("Xe nang thong minh");
  wm.setConnectTimeout(15);
  wm.setConfigPortalTimeout(120); 
  
  // Dòng lệnh ma thuật: Tắt chế độ "Chặn" (Blocking)
  wm.setConfigPortalBlocking(false);

  wm.autoConnect("Xe nang thong minh");
  device_id = WiFi.macAddress();
  
  // --- Khởi động Loadcell ---
  LoadCell_L.begin();
  LoadCell_R.begin();
  unsigned long stabilizingtime = 2000;  
  LoadCell_L.start(stabilizingtime, true);  
  LoadCell_R.start(stabilizingtime, true);
  
  if (LoadCell_L.getTareTimeoutFlag() || LoadCell_R.getTareTimeoutFlag()) {
    Serial.println("Loi: Kiem tra day noi DT/SCK cua Loadcell!");
    while (1);
  }
  
  LoadCell_L.setCalFactor(calibrationValue_L); 
  LoadCell_R.setCalFactor(calibrationValue_R);
  Serial.println("Da khoi dong xong, xin moi su dung xe");
  
  // Kích hoạt hàm docLoadCell chạy vĩnh viễn trên Lõi số 0 (Core 0)
  xTaskCreatePinnedToCore(docLoadCell, "TaskCore0", 10000, NULL, 1, &TaskCore0, 0);
}

void loop() {
  wm.process();

  float wL = LoadCell_L.getData();
  float wR = LoadCell_R.getData();

  // Bật lại lá chắn lọc nhiễu cho số liệu Server đẹp
  if (wL < 0.1) wL = 0.000;
  if (wR < 0.1) wR = 0.000;

  unsigned long currentMillis = millis();

  // Cập nhật mỗi 0.5 giây (500ms)
  if (currentMillis > t + 200) { 

    // --- TÍNH TOÁN VẬN TỐC & QUÃNG ĐƯỜNG ---
    float timeElapsed = (currentMillis - t) / 1000.0; 

    noInterrupts(); 
    unsigned long currentHits = magnetHits;
    interrupts();   

    unsigned long hitsInInterval = currentHits - previousHits; 
    float intervalDistance = hitsInInterval * distancePerTick; 
    float velocity = intervalDistance / timeElapsed;

    // --- GỬI DỮ LIỆU LÊN SERVER ---
    if (WiFi.status() == WL_CONNECTED) {
      digitalWrite(2, HIGH);
      static WiFiClientSecure client;
      static bool isClientSetup = false;
      if (!isClientSetup) {
        client.setInsecure ();
        isClientSetup = true;
      }
      HTTPClient http;
      http.setReuse (true);

      // ==========================================
      // NHIỆM VỤ 1: GỬI SỐ LIỆU CÂN (Mỗi 0.5s)
      // ==========================================
      http.begin(client, baseUrl + "/api/v1/metrics"); 
      http.addHeader("Content-Type", "application/json");
      http.addHeader("Connection", "keep-alive");

      String jsonData = "{";
      jsonData += "\"device_id\":\"" + device_id + "\",";
      jsonData += "\"f1\":" + String(wL, 3) + ",";
      jsonData += "\"f2\":" + String(wR, 3) + ",";
      //jsonData += "\"distance\":" + String(intervalDistance, 3);
      //jsonData += "\"velocity\":" + String(velocity, 3); //vận tốc
      jsonData += "}";

      int httpResponseCode = http.POST(jsonData);
      if (httpResponseCode > 0) {
        http.getString();
      }
      http.end();


      // ==========================================
      // NHIỆM VỤ 2: GỬI PING ĐIỂM DANH (Mỗi 3 phút)
      // ==========================================
      if (currentMillis - lastPingTime >= pingInterval) {
        http.begin(client, baseUrl + "/api/v1/devices/ping"); 
        http.addHeader("Content-Type", "application/json");
        http.addHeader("Connection", "keep-alive");
        String pingData = "{\"device_id\":\"" + device_id + "\"}";
        
        int pingResponse = http.POST(pingData);
        if (pingResponse > 0) {
          http.getString(); // Tương tự, dọn rác ống TCP
        }
        http.end(); 

        Serial.println(">>> DA GUI PING DIEM DANH LEN SERVER <<<");
        lastPingTime = currentMillis; 
      }
    } else {
      digitalWrite(2, LOW); 
      Serial.println("Mat mang WiFi");
    }

    // --- IN RA MÀN HÌNH ĐỂ THEO DÕI ---
    Serial.print("Trai: "); Serial.print(wL, 3);
    Serial.print(" | Phai: "); Serial.print(wR, 3);
    Serial.print(" || Quang duong: "); Serial.print(intervalDistance, 3);
    Serial.print(" m | Van toc: "); Serial.print(velocity, 3);
    Serial.println(" m/s");

    previousHits = currentHits;
    t = currentMillis; 
  }

  // --- LỆNH TỪ BÀN PHÍM ---
  if (Serial.available() > 0) {
    char inByte = Serial.read();
    if (inByte == 'r') {
      Serial.println("Dang reset WiFi...");
      WiFiManager wm;
      wm.resetSettings();
      ESP.restart();
    } 
  }
}
